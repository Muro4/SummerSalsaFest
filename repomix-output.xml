        return n + (s[(v - 20) % 10] || s[v] || s[0]);
      };
      setEditionText(`${getOrdinal(editionNumber)} Edition`);

      // 3. Start Butter-Smooth Auto-Scroll
      startAutoScroll();
      
      return () => {
        if (animationRef.current) cancelAnimationFrame(animationRef.current);

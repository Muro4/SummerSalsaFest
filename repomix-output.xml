                  <span className={mobileTextClass('/tickets')}>Prices</span>
                </Link>
                <Link href="/info" onClick={() => setMobileMenuOpen(false)} className={mobileWrapperClass('/info')}>
                  <span className={mobileTextClass('/info')}>Info</span>
                </Link>

                  { label: 'SSF 2024', value: '2024' }
                ]}
                variant="compact"
              />
            </div>
          </div>
        </div>

        {/* CONTROLS AREA */}
        
        {/* ROW 1: DESKTOP ACTION BUTTONS ON TOP */}
        <div className="hidden md:flex justify-end items-center gap-3 w-full mb-4 z-40 relative">
          <Button

        {/* ==================================================== */}
        {/* MOBILE ACCOUNT SIDE DRAWER (70% Width) */}
        {/* ==================================================== */}
        {mobileAccountOpen && user && (
          <div className="md:hidden fixed inset-0 z-[100] flex justify-end font-montserrat">

      </section>

      {/* 5. CALL TO ACTION */}
      <section className="py-24 md:py-32 px-4 md:px-6 text-center bg-salsa-white text-slate-900">
        <h2 className="font-bebas tracking-wide text-6xl md:text-8xl mb-6 md:mb-8 leading-none">{t('cta.title')}</h2>
